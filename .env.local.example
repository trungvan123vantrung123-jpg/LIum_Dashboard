# Copy file này thành .env.local và điền đúng thông tin từ Supabase Project Settings > API
# KHÔNG commit file .env.local thật lên Git — chỉ commit file .example này

# URL project Supabase, dạng https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# Anon/public key — dùng cho các thao tác đọc thông thường từ trình duyệt
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service role key — CHỈ dùng ở server (API routes), KHÔNG BAO GIỜ để lộ ra client
# Dùng cho các thao tác ghi quan trọng (xác nhận booking, hoàn tiền...) cần bỏ qua RLS
SUPABASE_SERVICE_ROLE_KEY=
